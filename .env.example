# =============================================================================
# xRuto backend — copy to .env (local) or set in Render → Environment
# =============================================================================
# Production (Render): set every variable in the dashboard. No secrets in git.
# Local dev: same keys as production if you want one Supabase; or omit SUPABASE_*
#            to use backend/db.json only (offline / sandbox).
# =============================================================================

# --- Supabase (required in production) ---
# Project Settings → API → Project URL and anon public key
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Server ---
PORT=5000
NODE_ENV=development
# production on Render: NODE_ENV=production (often set automatically)

# --- CORS: browser must be allowed to call this API ---
# Vercel production URL (no trailing slash), e.g. https://xruto.vercel.app
CLIENT_URL=http://localhost:5173
# Optional extra frontends (comma-separated, no spaces after commas is fine)
# CORS_EXTRA_ORIGINS=https://old-domain.com,https://preview-abc.vercel.app
# Set to false only if you use a custom domain and do not want automatic *.vercel.app
# CORS_ALLOW_VERCEL=true

# --- Auth ---
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# --- Geocoding (depot address → lat/lng) ---
# Per OSM policy, set a real app contact in production
# NOMINATIM_USER_AGENT=Xruto/1.0 (your-site.com; you@email.com)

# --- Optional: routing / maps ---
# HERE_API_KEY=

# --- Optional: email (password reset, etc.) ---
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# --- Link in password emails ---
# CLIENT_URL is used; override if the app lives elsewhere
# (already set above for CORS)
