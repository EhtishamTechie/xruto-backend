# Backend Environment Configuration
# Copy this file to .env for local development.
# On Render, add these values in the service Environment tab.

# ===========================================
# DATABASE CONFIGURATION (Supabase)
# Source: Supabase dashboard -> Project Settings -> API
# ===========================================
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ===========================================
# API KEYS
# Source: HERE developer portal
# ===========================================
HERE_API_KEY=YOUR_HERE_API_KEY

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# FRONTEND URL (for CORS)
# Source: your Vercel deployment URL
# ===========================================
CLIENT_URL=http://localhost:5173
# CLIENT_URL=https://your-frontend-domain.com

# ===========================================
# AUTH / EMAIL
# ===========================================
# Source: generate a strong random secret yourself
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Source: your email provider (Resend/SendGrid)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@xruto.com
